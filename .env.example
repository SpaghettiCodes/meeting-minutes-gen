# Backend stack — used by the API, CLI, and docker-compose.yml

# Google Gemini — get an API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TRANSCRIPTION_MODEL=gemini-2.0-flash
# OpenAI-compatible Gemini endpoint (default shown below)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Data directories (relative to project root)
TRANSCRIPT_DIR=data/transcripts
TEMPLATE_DIR=data/templates
OUTPUT_DIR=data/output

# LLM generation settings
TEMPERATURE=0.2
# Gemini 2.0 Flash supports up to ~1M tokens; backend truncates very large prompts to fit.
LLM_MAX_MODEL_LEN=1048576
MAX_TOKENS=8192
# TEMPLATE_CONVERSION_MAX_INPUT_CHARS=32000
GEMINI_REQUEST_TIMEOUT=600

# Background generation tasks (stored in MongoDB)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=meeting_minutes
MONGODB_TASKS_COLLECTION=tasks
MAX_CONCURRENT_GENERATIONS=1
