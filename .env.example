# Local llama.cpp — generation + template conversion
# From Docker use host.docker.internal instead of localhost
LLM_BASE_URL=http://host.docker.internal:8002/v1
# Match GET http://localhost:8002/v1/models → data[0].id
LLM_MODEL=/models/your-model.gguf
LLM_API_KEY=not-needed

# Local vLLM Whisper — transcription
# Start server with: VLLM_MAX_AUDIO_CLIP_FILESIZE_MB=1024 vllm serve ...
WHISPER_BASE_URL=http://host.docker.internal:8000/v1
WHISPER_MODEL=openai/whisper-small
WHISPER_API_KEY=not-needed

# Data directories (relative to project root)
TRANSCRIPT_DIR=data/transcripts
TEMPLATE_DIR=data/templates
OUTPUT_DIR=data/output

# LLM generation settings
TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=600
WHISPER_REQUEST_TIMEOUT=600

# Background generation tasks (stored in MongoDB)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=meeting_minutes
MONGODB_TASKS_COLLECTION=tasks
MAX_CONCURRENT_GENERATIONS=1
